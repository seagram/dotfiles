font-size = 17
theme = vague
window-colorspace = display-p3
bold-color = bright
background-opacity = 0.9
background-blur = 15
unfocused-split-opacity = 0.15
minimum-contrast = 3

mouse-hide-while-typing = true 
shell-integration-features = no-cursor
cursor-style = underline
cursor-style-blink = false
adjust-underline-thickness = 50%
adjust-cursor-thickness = 200%

window-padding-x = 9
window-padding-y = 9
window-padding-balance = true
window-padding-color = background
resize-overlay = never

macos-window-shadow = false
macos-window-buttons = hidden
macos-titlebar-style = hidden
macos-icon = glass

clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

app-notifications = false
desktop-notifications = false
confirm-close-surface = false
quit-after-last-window-closed = true

custom-shader=shaders/cursor_warp.glsl

# command=/opt/homebrew/bin/tmux

keybind = ctrl+equal=new_tab
keybind = ctrl+minus=close_tab
keybind = ctrl+right_bracket=next_tab
keybind = ctrl+left_bracket=previous_tab

keybind = ctrl+apostrophe=new_split:right
keybind = ctrl+semicolon=new_split:down

keybind = ctrl+comma=goto_split:left
keybind = ctrl+period=goto_split:right

keybind = ctrl+a>ctrl+j=resize_split:down,15
keybind = ctrl+a>ctrl+k=resize_split:up,15
keybind = ctrl+a>ctrl+h=resize_split:left,15
keybind = ctrl+a>ctrl+l=resize_split:right,15
